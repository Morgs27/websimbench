  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "noEmit": false,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": false
  },
  "include": ["src"]
}
