{
  "name": "websimbench",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "vite",
    "build": "npm run build --workspace @websimbench/agentyx && tsc && vite build",
    "build:app": "tsc && vite build",
    "build:pkg": "npm run build --workspace @websimbench/agentyx",
    "preview": "vite preview",
    "test": "npm run test --workspace @websimbench/agentyx",
    "test:app": "vitest",
    "typecheck": "tsc --noEmit && npm run typecheck --workspace @websimbench/agentyx",
    "format": "prettier --write \"{src,packages}/**/*.{ts,tsx,css,md}\"",
    "prepare": "husky"
  },
  "dependencies": {
    "@base-ui/react": "^1.0.0",
    "@fontsource-variable/nunito-sans": "^5.2.7",
    "@phosphor-icons/react": "^2.1.10",
    "@types/node": "^24.10.1",
    "@types/prismjs": "^1.26.5",
    "@websimbench/agentyx": "workspace:*",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.575.0",
    "prettier": "^3.7.3",
    "prismjs": "^1.29.0",
    "radix-ui": "^1.4.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-resizable-panels": "^3.0.6",
    "react-simple-code-editor": "^0.13.1",
    "shadcn": "^3.6.3",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "tailwindcss-animate": "^1.0.7",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.37",
    "@types/react-dom": "^18.2.15",
    "@vitejs/plugin-react": "^4.2.0",
    "@vitest/browser": "^4.0.15",
    "@vitest/browser-playwright": "^4.0.15",
    "@webgpu/types": "^0.1.66",
    "autoprefixer": "^10.4.23",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "playwright": "^1.57.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.2.2",
    "vite": "^5.0.0",
    "vitest": "^4.0.15"
  },
  "lint-staged": {
    "*.{ts,tsx,css,md}": [
      "prettier --write"
    ]
  }
}